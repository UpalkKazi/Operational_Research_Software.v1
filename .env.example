# AI Provider Configuration
# Choose one: 'anthropic' or 'openai' (or leave empty for auto-detection)
AI_PROVIDER=

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_key_here

# Model Configuration
# Default model (will use provider-specific default if not set)
# Anthropic examples: claude-sonnet-4-5-20250929, claude-3-5-sonnet-20241022
# OpenAI examples: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
DEFAULT_MODEL=
MAX_TOKENS=4096
TEMPERATURE=0.3

# Solver Configuration
DEFAULT_SOLVER=pulp
SOLVER_TIME_LIMIT=300  # seconds

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Optional: Commercial Solver Licenses
# GUROBI_LICENSE_FILE=/path/to/gurobi.lic
# CPLEX_STUDIO_KEY=your_cplex_key

# Cache Configuration
ENABLE_CACHE=True
CACHE_TTL=3600  # seconds

# API Configuration (if deploying as API)
API_HOST=0.0.0.0
API_PORT=8000
